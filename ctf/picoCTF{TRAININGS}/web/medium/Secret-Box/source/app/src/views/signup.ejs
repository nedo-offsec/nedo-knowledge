<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Secrets Vault</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
            background-color: #f9f9f9;
            color: #2d3436;
            line-height: 1.6;
        }
        
        .container {
            padding: 40px;
            text-align: center;
            margin: 0 auto;
        }
        
        .description {
            font-size: 1.1rem;
            margin-bottom: 36px;
            color: #636e72;
        }

        form {
            max-width: 400px;
            margin: 0 auto;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
            text-align: left;
        }
        
        .input {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 20px;
            border-radius: 8px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .input:focus {
            border-color: #5649c0;
            box-shadow: 0 0 0 3px rgba(86, 73, 192, 0.2);
        }
        
        .button {
            display: block;
            width: 100%;
            padding: 14px 24px;
            text-align: center;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            text-transform: capitalize;
            background: #5649c0;
            color: white;
            cursor: pointer;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
		<% if (message) { %>
			<p style="color: green;"><%= message %></p>
		<% } %>

		<% if (error) { %>
			<p style="color: red;"><%= error %></p>
		<% } %>

        <div class="description">Sign Up</div>

        <form method="POST" action="/signup">
            <label for="username">Name:</label>
            <input type="text" id="username" name="username" class="input">
            
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" class="input">
            
            <input type="submit" value="Submit" class="button">
        </form>
    </div>
</body>
</html>
